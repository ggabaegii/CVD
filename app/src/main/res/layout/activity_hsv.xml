<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HSV">


    <TextView
        android:id="@+id/title_auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HSV"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.021" />

    <EditText
        android:id="@+id/name_auto"
        android:layout_width="230dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:ems="10"
        android:inputType="textShortMessage"
        android:hint="제목입력"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.274"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_auto" />

    <Button
        android:id="@+id/save_auto"
        android:layout_width="74dp"
        android:layout_height="54dp"
        android:text="저장"
        app:layout_constraintBottom_toBottomOf="@+id/name_auto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.296"
        app:layout_constraintStart_toEndOf="@+id/name_auto"
        app:layout_constraintTop_toBottomOf="@+id/title_auto"
        app:layout_constraintVertical_bias="1.0" />

    <ImageView
        android:id="@+id/hsv_imageView"
        android:layout_width="350dp"
        android:layout_height="450dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_auto"
        app:srcCompat="@drawable/rectangle_2" />


    <SeekBar
        android:id="@+id/Bar_H"
        android:layout_width="300dp"
        android:layout_height="20dp"
        android:layout_marginTop="16dp"
        android:max="360"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.671"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hsv_imageView" />

    <SeekBar
        android:id="@+id/Bar_V"
        android:layout_width="300dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:max="100"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.671"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Bar_S"
        app:layout_constraintVertical_bias="0.016" />

    <SeekBar
        android:id="@+id/Bar_S"
        android:layout_width="300dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:max="100"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.671"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/Bar_H" />

    <TextView
        android:id="@+id/bar_H"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="H"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/Bar_H"
        app:layout_constraintHorizontal_bias="0.715"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hsv_imageView" />

    <TextView
        android:id="@+id/bar_S"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="S"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/Bar_V"
        app:layout_constraintHorizontal_bias="0.717"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bar_H" />

    <TextView
        android:id="@+id/bar_V"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="V"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/Bar_S"
        app:layout_constraintHorizontal_bias="0.717"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bar_S" />


</androidx.constraintlayout.widget.ConstraintLayout>